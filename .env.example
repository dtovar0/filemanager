# Nexus FileManager - Environment Configuration Example
# Copy this to .env and fill in the values

# System Security
SECRET_KEY=yoursecret-key-change-this-to-something-very-long-and-random

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=filemanager_user
DB_PASS=securepassword
DB_NAME=filemanager_db

# Debug Mode (Set to False in production)
DEBUG=False
